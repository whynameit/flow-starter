# Required only when you run with --use-claude.
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Set this to the Claude model available in your Anthropic account.
CLAUDE_MODEL=your-claude-model-name

# Your local note vault.
OBSIDIAN_VAULT=/Users/rh/Documents/Obsidian Vault

# Optional: local clone of your GitHub Pages/al-folio site.
BLOG_SITE_DIR=/Users/rh/Documents/whynameit.github.io
BLOG_TITLE=rh's blog
BLOG_AUTHOR=whynameit
BLOG_BASE_URL=https://whynameit.github.io
